# Quick Start - Interactive launcher for ROS2 KPI Toolkit

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR" || exit

# Colors
GREEN=$(printf '\033[0;32m')
YELLOW=$(printf '\033[1;33m')
NC=$(printf '\033[0m')

# Auto-setup
source ./auto-setup.sh

clear
echo "=========================================="
echo "  ROS2 KPI Toolkit - Quick Start"
echo "=========================================="
echo ""
echo "What would you like to do?"
echo ""
echo "  ${GREEN}1)${NC} Monitor my ROS2 application"
echo "  ${GREEN}2)${NC} Wandering simulation"
echo "  ${GREEN}3)${NC} Pick-n-Place simulation"
echo "  ${GREEN}4)${NC} Analyze rosbag / results"
echo "  ${GREEN}5)${NC} Quick health check"
echo "  ${GREEN}6)${NC} Grafana dashboards"
echo "  ${GREEN}7)${NC} Advanced options"
echo "  ${GREEN}0)${NC} Exit"
echo ""
read -rp "Choice [0-7]: " choice

case $choice in
    1)
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "  Monitor ROS2 Application"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""

        # Check if any nodes are running
        nodes=$(ros2 node list 2>/dev/null | grep -v "^$")
        node_count=$(echo "$nodes" | grep -cv "^$")

        if [ "$node_count" -eq 0 ]; then
            echo "${YELLOW}⚠️  No ROS2 nodes detected.${NC}"
            echo ""
            echo "Please start your ROS2 application first, then run this again."
            echo ""
            echo "Examples:"
            echo "  ros2 launch wandering_gazebo_tutorial wandering.launch.py"
            echo "  ros2 run turtlesim turtlesim_node"
            exit 1
        fi

        echo "Available nodes:"
        echo "$nodes" | nl -w2 -s") "
        echo ""
        read -rp "Monitor specific node? (enter number or 'a' for all): " node_choice

        if [[ "$node_choice" =~ ^[0-9]+$ ]]; then
            target_node=$(echo "$nodes" | sed -n "${node_choice}p")
            echo ""
            echo "Monitoring: $target_node"
            read -rp "Duration (seconds, default=60): " duration
            duration=${duration:-60}
            uv run python src/monitor_stack.py --node "$target_node" --duration "$duration"
        else
            echo ""
            read -rp "Duration (seconds, default=60): " duration
            duration=${duration:-60}
            uv run python src/monitor_stack.py --duration "$duration"
        fi
        ;;

    2)
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "  Wandering Simulation"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""
        echo "  ${GREEN}1)${NC} Single run  (monitor + KPI analysis)"
        echo "  ${GREEN}2)${NC} Single run  + rosbag recording"
        echo "  ${GREEN}3)${NC} Single run  + rosbag recording + plots"
        echo "  ${GREEN}4)${NC} Benchmark   (multiple runs, then aggregate KPIs)"
        echo "  ${GREEN}0)${NC} Back"
        echo ""
        read -rp "Choice: " w_choice

        case $w_choice in
            1)
                read -rp "Goals to reach (default=5, 0=ignore): " goals
                goals=${goals:-5}
                read -rp "Timeout in seconds (default=120): " timeout
                timeout=${timeout:-120}
                bash src/wandering_run.sh --goals "$goals" --timeout "$timeout"
                ;;
            2)
                read -rp "Goals to reach (default=5, 0=ignore): " goals
                goals=${goals:-5}
                read -rp "Timeout in seconds (default=120): " timeout
                timeout=${timeout:-120}
                bash src/wandering_run.sh --goals "$goals" --timeout "$timeout" --record
                ;;
            3)
                read -rp "Goals to reach (default=5, 0=ignore): " goals
                goals=${goals:-5}
                read -rp "Timeout in seconds (default=120): " timeout
                timeout=${timeout:-120}
                bash src/wandering_run.sh --goals "$goals" --timeout "$timeout" --record --plot
                ;;
            4)
                read -rp "Number of runs (default=25): " runs
                runs=${runs:-25}
                read -rp "Timeout per run in seconds (default=120): " timeout
                timeout=${timeout:-120}
                read -rp "Pause between runs in seconds (default=30): " pause
                pause=${pause:-30}
                bench_dir="monitoring_sessions/wandering/bench_$(date +%Y%m%d_%H%M%S)"
                mkdir -p "$bench_dir"
                for i in $(seq 1 "$runs"); do
                    echo "--- Run $i / $runs ---"
                    bash src/wandering_run.sh --goals "$goals" --timeout "$timeout" --record --output-parent "$bench_dir"
                    [[ $i -lt $runs ]] && sleep "$pause"
                done
                uv run python src/aggregate_kpi.py "$bench_dir"
                ;;
            0) echo "Back."; exit 0 ;;
            *) echo "Invalid choice"; exit 1 ;;
        esac
        ;;

    3)
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "  Pick-n-Place Simulation"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""
        echo "  ${GREEN}1)${NC} Single run  (monitor + KPI analysis)"
        echo "  ${GREEN}2)${NC} Single run  + rosbag recording"
        echo "  ${GREEN}3)${NC} Single run  + rosbag recording + plots"
        echo "  ${GREEN}4)${NC} Benchmark   (multiple runs, then aggregate KPIs)"
        echo "  ${GREEN}0)${NC} Back"
        echo ""
        read -rp "Choice: " pn_choice

        case $pn_choice in
            1)
                read -rp "Timeout in seconds (default=300): " timeout
                timeout=${timeout:-300}
                bash src/picknplace_run.sh --timeout "$timeout"
                ;;
            2)
                read -rp "Timeout in seconds (default=300): " timeout
                timeout=${timeout:-300}
                bash src/picknplace_run.sh --timeout "$timeout" --record
                ;;
            3)
                read -rp "Timeout in seconds (default=300): " timeout
                timeout=${timeout:-300}
                bash src/picknplace_run.sh --timeout "$timeout" --record --plot
                ;;
            4)
                read -rp "Number of runs (default=25): " runs
                runs=${runs:-25}
                read -rp "Timeout per run in seconds (default=300): " timeout
                timeout=${timeout:-300}
                read -rp "Pause between runs in seconds (default=30): " pause
                pause=${pause:-30}
                bench_dir="monitoring_sessions/picknplace/bench_$(date +%Y%m%d_%H%M%S)"
                mkdir -p "$bench_dir"
                for i in $(seq 1 "$runs"); do
                    echo "--- Run $i / $runs ---"
                    bash src/picknplace_run.sh --timeout "$timeout" --record --output-parent "$bench_dir"
                    [[ $i -lt $runs ]] && sleep "$pause"
                done
                uv run python src/aggregate_kpi.py "$bench_dir"
                ;;
            0) echo "Back."; exit 0 ;;
            *) echo "Invalid choice"; exit 1 ;;
        esac
        ;;

    4)
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "  Analyze Rosbag / Results"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""
        echo "  ${GREEN}1)${NC} Analyze last wandering session bag"
        echo "  ${GREEN}2)${NC} Analyze last pick-n-place session bag"
        echo "  ${GREEN}3)${NC} Analyze a specific bag (enter path)"
        echo "  ${GREEN}4)${NC} Aggregate benchmark results (enter bench dir)"
        echo "  ${GREEN}5)${NC} View cross-session KPI averages"
        echo "  ${GREEN}6)${NC} Level 2 pipeline KPI (end-to-end latency + drop rate)"
        echo "  ${GREEN}0)${NC} Back"
        echo ""
        read -rp "Choice: " analyze_choice

        case $analyze_choice in
            1)
                last_bag=$(find monitoring_sessions/wandering -maxdepth 2 -type d -name 'bag' 2>/dev/null | sort -r | head -1)
                if [ -z "$last_bag" ]; then echo "No wandering bag found."; exit 1; fi
                uv run python src/analyze_trigger_latency.py --bag "$last_bag" --summary-only
                ;;
            2)
                last_bag=$(find monitoring_sessions/picknplace -maxdepth 2 -type d -name 'bag' 2>/dev/null | sort -r | head -1)
                if [ -z "$last_bag" ]; then echo "No pick-n-place bag found."; exit 1; fi
                uv run python src/analyze_trigger_latency.py --bag "$last_bag" --summary-only
                ;;
            3)
                read -rp "Path to rosbag2 directory: " bag_path
                if [ -z "$bag_path" ]; then
                    echo "No path entered."
                    exit 1
                fi
                uv run python src/analyze_rosbag.py "$bag_path"
                ;;
            4)
                read -rp "Path to bench_* directory: " bench_path
                if [ -z "$bench_path" ]; then
                    echo "No path entered."
                    exit 1
                fi
                uv run python src/aggregate_kpi.py "$bench_path"
                ;;
            5)
                read -rp "Number of recent sessions to average (default=5): " runs
                runs=${runs:-5}
                uv run python src/view_average.py --runs "$runs"
                ;;
            6)
                last_kpi=$(find monitoring_sessions/wandering -maxdepth 2 -name 'kpi.json' 2>/dev/null | sort -r | head -1)
                if [ -z "$last_kpi" ]; then echo "No wandering kpi.json found. Run option 4→1 first."; exit 1; fi
                session_dir=$(dirname "$last_kpi")
                uv run python src/analyze_pipeline_latency.py \
                    --kpi "$last_kpi" \
                    --json-out "${session_dir}/kpi_level2.json"
                ;;
            0) echo "Back."; exit 0 ;;
            *) echo "Invalid choice"; exit 1 ;;
        esac
        ;;

    5)
        echo ""
        echo "Running quick health check (30 seconds)..."
        uv run python src/monitor_stack.py --duration 30
        ;;

    6)
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "  Grafana Dashboards"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""
        echo "  ${GREEN}1)${NC} Start Grafana/Prometheus"
        echo "  ${GREEN}2)${NC} Stop Grafana/Prometheus"
        echo "  ${GREEN}3)${NC} Check status"
        echo "  ${GREEN}4)${NC} Open Grafana in browser"
        echo ""
        read -rp "Choice: " grafana_choice

        case $grafana_choice in
            1) make grafana-start ;;
            2) make grafana-stop ;;
            3) make grafana-status ;;
            4) make grafana-open ;;
            *) echo "Invalid choice" ;;
        esac
        ;;

    7)
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "  Advanced Options"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""
        echo "  ${GREEN}1)${NC} Extended monitoring (5 minutes)"
        echo "  ${GREEN}2)${NC} Remote monitoring"
        echo "  ${GREEN}3)${NC} Interactive heatmap"
        echo "  ${GREEN}4)${NC} Visualize last session"
        echo "  ${GREEN}5)${NC} Show all commands (make help)"
        echo ""
        read -rp "Choice: " advanced_choice

        case $advanced_choice in
            1)
                read -rp "Node name (or press Enter for all): " node_name
                if [ -n "$node_name" ]; then
                    uv run python src/monitor_stack.py --node "$node_name" --duration 300
                else
                    uv run python src/monitor_stack.py --duration 300
                fi
                ;;
            2)
                read -rp "Remote IP address: " remote_ip
                read -rp "Remote user (default=$USER): " remote_user
                remote_user=${remote_user:-$USER}
                uv run python src/monitor_stack.py --remote-ip "$remote_ip" --remote-user "$remote_user"
                ;;
            3) uv run python demo_interactive_heatmap.py ;;
            4)
                last_session=$(find monitoring_sessions -maxdepth 1 -mindepth 1 -type d 2>/dev/null | sort -r | head -1)
                if [ -z "$last_session" ]; then echo "No sessions found."; exit 1; fi
                timing="${last_session}/graph_timing.csv"
                if [ -f "$timing" ]; then
                    uv run python src/visualize_timing.py "$timing" --delays --frequencies --show
                else
                    echo "No graph_timing.csv in $last_session"
                fi
                ;;
            5) make help ;;
            *) echo "Invalid choice" ;;
        esac
        ;;

    0)
        echo "Goodbye!"
        exit 0
        ;;

    *)
        echo "Invalid choice"
        exit 1
        ;;
esac

echo ""
echo "Done!"
