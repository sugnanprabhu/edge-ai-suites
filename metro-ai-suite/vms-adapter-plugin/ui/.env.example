# VMS-UI Environment Variables
# Copy this file to .env and configure as needed

# Port to expose the UI (maps to container port 80)
UI_PORT=3000

# Backend API host (for nginx proxy)
# Default uses host.docker.internal to reach backend on host
# If backend is in same Docker network, use: vms-plugin:8080
BACKEND_HOST=host.docker.internal:8085

# MediaMTX WebRTC base URL (publicly reachable from the browser).
# Used as the iframe src origin for the live video player.
# Must be the host:port where MediaMTX is exposed (default port: 8889).
# WHEP readiness polling goes through the /whep reverse-proxy, not this URL.
VITE_MEDIAMTX_BASE=http://<mediamtx-host>:8889
