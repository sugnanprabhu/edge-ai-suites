# Docker image configuration
REGISTRY=intel/
TAG=latest

# Compose project name
PROJECT_NAME=live-captioning

# Host address reachable by the browser for WebRTC.
# Run `bash scripts/setup_env.sh` to fill this in automatically.
HOST_IP=127.0.0.1

# Ports
WHIP_SERVER_PORT=8889
EVAM_HOST_PORT=8040
EVAM_PORT=8080
DASHBOARD_PORT=4173
MQTT_PORT=1883
METRICS_SERVICE_PORT=9090

# WebRTC defaults
WEBRTC_PEER_ID=stream
WEBRTC_BITRATE=5000

# Feature flags
ALERT_MODE=false
ENABLE_DETECTION_PIPELINE=false
ENABLE_EMBEDDING=false
CAPTION_HISTORY=3

# Optional default stream URL shown in the UI
DEFAULT_RTSP_URL=

# Model download helper
OVMS_RELEASE_TAG=v2026.0
HUGGINGFACEHUB_API_TOKEN=
MODEL_DOWNLOAD_EPHEMERAL_SCRIPT_URL=https://raw.githubusercontent.com/open-edge-platform/edge-ai-libraries/main/microservices/model-download/scripts/get_model.sh
