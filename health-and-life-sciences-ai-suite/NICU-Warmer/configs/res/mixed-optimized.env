# NICU Warmer — Mixed Optimized Device Profile (DEFAULT)
# Distributes workloads across GPU, CPU, and NPU for optimal throughput.
#   Detection models (person/patient/latch) → GPU  (best throughput for object detection)
#   rPPG (MTTS-CAN)                         → CPU  (custom Python callback, not GPU-accelerated)
#   Action Recognition (encoder/decoder)    → NPU  (offloads from GPU, frees GPU for detection)
DECODE=decodebin3 ! vapostproc ! "video/x-raw(memory:VAMemory)"
DETECTION_DEVICE=GPU
DETECTION_OPTIONS=ie-config=GPU_THROUGHPUT_STREAMS=2 nireq=2
RPPG_DEVICE=CPU
ACTION_DEVICE=NPU
PRE_PROCESS=pre-process-backend=va-surface-sharing
PRE_PROCESS_CONFIG=pre-process-config=resize_type=standard
DEVICE_PROFILE=mixed-optimized

# Model paths and precision (switch ACTION to FP16 once FP16 models are downloaded)
PERSON_MODEL=/models/person-detect-fp32.xml
PATIENT_MODEL=/models/patient-detect-fp32.xml
LATCH_MODEL=/models/latch-detect-fp32.xml
RPPG_MODEL=/models/rppg/mtts_can.xml
ACTION_ENCODER=/models/action/FP32/action-recognition-0001-encoder.xml
ACTION_DECODER=/models/action/FP32/action-recognition-0001-decoder.xml
DETECTION_PRECISION=FP32
ACTION_PRECISION=FP32
RPPG_PRECISION=FP32
